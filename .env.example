# Copy to .env and fill in. Two ways to run:

# --- Option A: your LiteLLM instance (no Anthropic credits needed) ---
# The key here is your LiteLLM VIRTUAL KEY (often starts sk-...), not an
# Anthropic key. The Anthropic SDK talks to LiteLLM's /v1/messages endpoint.
ANTHROPIC_BASE_URL=http://192.168.132.144:4000
ANTHROPIC_API_KEY=<your-litellm-virtual-key>

# LiteLLM names models per its own config — they may not match Anthropic's
# public IDs. Run `python check_setup.py` to list what yours serves, then set:
# PROSPECT_MODEL=claude-opus-4-8

# --- Option B: Anthropic API directly ---
# Leave ANTHROPIC_BASE_URL unset/commented, and use a real Anthropic key from
# https://console.anthropic.com -> Settings -> API Keys (requires credits).
# ANTHROPIC_API_KEY=sk-ant-...
